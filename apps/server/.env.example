# HAForge Server Environment Variables
# Copy this file to .env and fill in the values

# Database connection string (PostgreSQL)
DATABASE_URL=postgres://user:password@localhost:5432/haforge

# Better Auth secret (min 32 chars, generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET=

# Better Auth base URL
BETTER_AUTH_URL=http://localhost:3000

# CORS origin (frontend URL)
CORS_ORIGIN=http://localhost:3001

# Node environment
NODE_ENV=development

# Secret encryption key for encrypting stored secrets (64 hex chars, generate with: openssl rand -hex 32)
SECRET_ENCRYPTION_KEY=
